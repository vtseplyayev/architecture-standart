@startuml application-integration
' Схема интеграции приложений — Открытие депозита (as-is)
' Нотация: C4 System Landscape diagram (C4-PlantUML)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Схема интеграции приложений — Открытие депозита (as-is). Нотация: C4 System Landscape.

' Тег для ручного обмена (узкое место): пунктир + оранжевый цвет
AddRelTag("manual", $lineStyle = DashedLine(), $lineColor = "#B07000", $textColor = "#B07000")

' ===== Участники (Person) =====
Person(client, "Клиент", "Хочет открыть депозит")
Person(cc, "Оператор кол-центра", "Принимает звонки, заводит обращения")
Person(front, "Сотрудник фронт-офиса", "Отделение: приём клиента, оформление и выдача документов")
Person(back, "Менеджер депозитов", "Бэк-офис: обработка заявок и расчёт ставки")
Person(credit, "Аналитик отдела кредитования", "Оценка кредитного риска; нет доступа к данным депозитов (ИБ)")

' ===== Системы (Software System) =====
System(abs, "АБС — Автоматизированная банковская система", "Ядро банка: открытие и ведение депозитов, раздел кредитного риска, СМС-оповещения, хранение договоров и документов, учёт выданных кредитов/депозитов")
System(crm, "Система кол-центра (CRM)", "Регистрация обращений клиентов кол-центра")
System(email, "Корпоративная почта (Email)", "Ручной обмен данными между подразделениями")
System(excel, "Excel-файл расчёта ставок", "Ручной расчёт процентной ставки по депозиту")
System_Ext(cb, "ЦБ РФ", "Ставка рефинансирования (внешний источник)")

' ===== Связи (label + [технология]) =====
' Сплошные — системная/автоматическая интеграция; пунктир (tag=manual) — ручной обмен
Rel(client, cc, "Звонит уточнить условия", "Телефон", $tags = "manual")
Rel(cc, crm, "Заводит обращение", "UI")
Rel(crm, abs, "Передаёт обращение", "Интеграция")
Rel(back, abs, "Обрабатывает заявку, вводит ставку", "UI")
Rel(abs, client, "Оповещает о готовой ставке", "SMS")
Rel(client, front, "Приходит в отделение", "Лично", $tags = "manual")
Rel(front, email, "Запрос ставки в бэк-офис", "Email", $tags = "manual")
Rel(email, back, "Доставляет письма", "Email", $tags = "manual")
Rel(credit, abs, "Анализирует кредитный риск", "UI, раздел АБС")
Rel(credit, email, "Передаёт данные по риску", "Email", $tags = "manual")
Rel(back, excel, "Рассчитывает ставку", "Файл .xlsx", $tags = "manual")
Rel(cb, excel, "Ставка рефинансирования (ежедневно)", "Внешние данные", $tags = "manual")
Rel(back, email, "Отправляет ставку во фронт-офис", "Email", $tags = "manual")
Rel(front, abs, "Создаёт депозит, загружает документы", "UI")
Rel(abs, email, "Выгрузка показателей кред./деп. (ежедневно)", "Excel по почте", $tags = "manual")

SHOW_LEGEND()
@enduml