<mxfile host="app.diagrams.net" type="device">
  <diagram id="app-integration" name="Интеграция приложений (as-is)">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Схема интеграции приложений — Открытие депозита (as-is). Участники процесса, ИТ-системы и способы интеграции." style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="900" height="24" as="geometry" />
        </mxCell>

        <!-- swimlane labels -->
        <mxCell id="lane_actors" value="Участники" style="text;html=1;align=center;fontStyle=1;fontSize=11;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="150" height="20" as="geometry" /></mxCell>
        <mxCell id="lane_sys" value="Системы / каналы интеграции" style="text;html=1;align=center;fontStyle=1;fontSize=11;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="270" y="70" width="190" height="20" as="geometry" /></mxCell>
        <mxCell id="lane_abs" value="АБС (ядро)" style="text;html=1;align=center;fontStyle=1;fontSize=11;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="560" y="70" width="340" height="20" as="geometry" /></mxCell>

        <!-- ===== Actors ===== -->
        <mxCell id="A_client" value="Клиент" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1"><mxGeometry x="80" y="120" width="40" height="70" as="geometry" /></mxCell>
        <mxCell id="A_cc" value="Оператор&#10;кол-центра" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="230" width="150" height="55" as="geometry" /></mxCell>
        <mxCell id="A_front" value="Сотрудник фронт-офиса&#10;(отделение)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="320" width="150" height="55" as="geometry" /></mxCell>
        <mxCell id="A_back" value="Менеджер депозитов&#10;(бэк-офис)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="430" width="150" height="55" as="geometry" /></mxCell>
        <mxCell id="A_credit" value="Аналитик&#10;отдела кредитования" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="540" width="150" height="55" as="geometry" /></mxCell>

        <!-- ===== Systems / integration channels ===== -->
        <mxCell id="S_crm" value="Система кол-центра&#10;(CRM)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="270" y="230" width="190" height="55" as="geometry" /></mxCell>
        <mxCell id="S_email" value="Корпоративная почта&#10;(Email) — ручной обмен" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="270" y="360" width="190" height="55" as="geometry" /></mxCell>
        <mxCell id="S_excel" value="Excel-файл&#10;расчёта ставок" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="270" y="470" width="190" height="55" as="geometry" /></mxCell>
        <mxCell id="S_cb" value="ЦБ РФ&#10;ставка рефинансирования&#10;(внешний источник)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="270" y="590" width="190" height="60" as="geometry" /></mxCell>

        <!-- ===== АБС container ===== -->
        <mxCell id="ABS" value="АБС — Автоматизированная банковская система" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#2E75B6;strokeWidth=2;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="100" width="340" height="560" as="geometry" /></mxCell>
        <mxCell id="M_front" value="АРМ фронт-офиса&#10;(создание депозита, документы)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="140" width="300" height="60" as="geometry" /></mxCell>
        <mxCell id="M_back" value="Модуль бэк-офиса&#10;(обработка заявок, ввод ставки)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="230" width="300" height="60" as="geometry" /></mxCell>
        <mxCell id="M_risk" value="Модуль кредитного риска&#10;(раздел отдела кредитования)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="320" width="300" height="60" as="geometry" /></mxCell>
        <mxCell id="M_sms" value="Подсистема СМС-оповещений" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="410" width="300" height="50" as="geometry" /></mxCell>
        <mxCell id="M_doc" value="Хранилище договоров и документов" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="490" width="300" height="50" as="geometry" /></mxCell>
        <mxCell id="M_calc" value="Учёт выданных кредитов и депозитов&#10;(показатели для расчёта ставки)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="570" width="300" height="60" as="geometry" /></mxCell>

        <!-- ===== Flows ===== -->
        <mxCell id="E1" value="1. Звонок: уточнение условий" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82B366;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="A_client" target="A_cc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E2" value="2. Заведение обращения" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82B366;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="A_cc" target="S_crm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E3" value="3. Передача обращения в АБС&#10;(интеграция)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6C8EBF;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="S_crm" target="M_back"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E4" value="4. Обработка заявки,&#10;ввод ставки" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82B366;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="A_back" target="M_back"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E5" value="5. СМС: ставка готова,&#10;прийти в отделение" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6C8EBF;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="M_sms" target="A_client"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E5b" value="внутр. триггер" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#6C8EBF;strokeWidth=1;fontSize=8;" edge="1" parent="1" source="M_back" target="M_sms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E6" value="6. Визит в отделение" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82B366;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="A_client" target="A_front"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E7" value="7. Письмо в бэк-офис:&#10;запрос ставки" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#D79B00;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="A_front" target="S_email"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E8" value="8. Доставка писем" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#D79B00;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="S_email" target="A_back"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E9" value="9. Анализ кредитного риска&#10;клиента" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82B366;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="A_credit" target="M_risk"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E10" value="10. Данные по риску письмом&#10;(нет прямого доступа — ИБ)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#D79B00;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="A_credit" target="S_email"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E11" value="11. Ручной расчёт ставки" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#D79B00;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="A_back" target="S_excel"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E12" value="Ежедневно: ставка ЦБ" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#9673A6;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="S_cb" target="S_excel"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E13" value="Ежедневно: показатели по кредитам/&#10;депозитам Excel-файлом по почте" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#D79B00;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="M_calc" target="S_email"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E14" value="12. Ставка ответным письмом&#10;во фронт-офис" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#D79B00;strokeWidth=2;fontSize=9;exitX=0;exitY=0.5;" edge="1" parent="1" source="S_email" target="A_front"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E15" value="13. Создание депозита,&#10;загрузка подписанных документов" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6C8EBF;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="A_front" target="M_front"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="E16" value="14. Подтверждение,&#10;подписание документов" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82B366;strokeWidth=1.5;fontSize=9;" edge="1" parent="1" source="A_front" target="A_client"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Note -->
        <mxCell id="note_ib" value="Ограничение ИБ: сотрудники депозитов и кредитов не имеют доступа к данным друг друга. Поэтому обмен идёт только через письма (Email) и Excel — отсюда задержки и ручной труд." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="40" y="630" width="220" height="100" as="geometry" /></mxCell>

        <!-- Legend -->
        <mxCell id="lg_title" value="Условные обозначения" style="text;html=1;align=left;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="560" y="680" width="200" height="20" as="geometry" /></mxCell>
        <mxCell id="lg_sys" value="Автоматическая интеграция (система↔система)" style="text;html=1;align=left;fontSize=9;fontColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="560" y="700" width="300" height="16" as="geometry" /></mxCell>
        <mxCell id="lg_man" value="Ручной обмен (Email / Excel / звонок) — узкое место" style="text;html=1;align=left;fontSize=9;fontColor=#D79B00;" vertex="1" parent="1"><mxGeometry x="560" y="716" width="300" height="16" as="geometry" /></mxCell>
        <mxCell id="lg_act" value="Действие сотрудника / клиента" style="text;html=1;align=left;fontSize=9;fontColor=#82B366;" vertex="1" parent="1"><mxGeometry x="560" y="732" width="300" height="16" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
