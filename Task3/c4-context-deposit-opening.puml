@startuml c4-context-deposit-opening
' C4 Level 1 — System Context. Открытие депозитов онлайн (MVP)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Диаграмма контекста (C4 L1) — Открытие депозитов онлайн (MVP)

AddRelTag("async", $lineStyle = DashedLine())

' ===== Действующие лица =====
Person(new_client, "Новый клиент", "Подаёт заявку на депозит на сайте")
Person(client, "Действующий клиент", "Подаёт заявку на депозит в интернет-банке")
Person(cc_mgr, "Менеджер кол-центра", "Обрабатывает заявки с сайта")
Person(bo_dep, "Менеджер бэк-офиса депозитов", "Согласует ставку, открывает депозит")
Person(bo_cred, "Сотрудник бэк-офиса кредитов", "Ведёт ставки/риск (разграниченный доступ)")

' ===== Системы =====
System(site, "Публичный сайт", "Витрина депозитов и форма заявки для новых клиентов")
System(ib, "Интернет-банк", "Просмотр депозитов и персональных ставок, онлайн-подача заявки, СМС-подтверждение")
System(crm, "Система кол-центра (CRM)", "Регистрация и обработка обращений")
System(abs, "АБС", "Ядро банка: открытие/ведение депозитов, ведение ставок, кредитный риск")

System_Ext(sms_gw, "СМС-шлюз", "Внешний провайдер отправки SMS")
System_Ext(cb, "ЦБ РФ", "Ставка рефинансирования")

' ===== Связи (Use Cases) =====
Rel(new_client, site, "Смотрит ставки, подаёт заявку (ФИО, телефон)", "HTTPS/TLS")
Rel(site, crm, "Создаёт заявку нового клиента", "HTTPS/REST")
Rel(cc_mgr, crm, "Обрабатывает заявку, предлагает условия")
Rel_Back(new_client, cc_mgr, "Звонок, приглашение в отделение (KYC)", "Телефон")

Rel(client, ib, "Смотрит депозиты/персональные ставки, подаёт заявку", "HTTPS/TLS")
Rel(ib, abs, "Передаёт заявки, получает ставки и события", "Kafka, async", $tags = "async")
Rel(ib, sms_gw, "Отправляет коды и уведомления", "SMPP/HTTPS")
Rel(sms_gw, client, "СМС: код подтверждения и уведомления", "SMS")

Rel(bo_dep, abs, "Согласует ставку, подтверждает и открывает депозит", "UI")
Rel(bo_cred, abs, "Ведёт ставки/риск (разграниченный доступ)", "UI")
Rel(cb, abs, "Ставка рефинансирования (ежедневно)", "Внешние данные")

SHOW_LEGEND()
@enduml